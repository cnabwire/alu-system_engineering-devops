#!/usr/bin/env bash
# Sets up Nginx to meet ALU checker requirements

apt-get update -y
apt-get install -y nginx

# Ensure nginx starts on boot
update-rc.d nginx defaults
sudo service nginx restart 

# Create web root and exact index content
mkdir -p /var/www/html
printf "Holberton School" > /var/www/html/index.html

# Configure nginx to use our web root
cat > /etc/nginx/sites-available/default << 'EOF'
server {
    listen 80 default_server;
    listen [::]:80 default_server;

    root /var/www/html;
    index index.html index.htm;

    server_name _;

    location / {
        try_files $uri $uri/ =404;
    }

    error_page 404 /custom_404.html;
}
EOF

# Create custom error page
printf "Page not found" > /var/www/html/custom_404.html

# Restart nginx to apply changes
sudo service nginx restart
